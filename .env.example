# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Get yours by messaging @userinfobot. This is the ONLY access barrier, so keep it tight.
ALLOWED_USER_IDS=123456789

# Directory Claude Code starts in (absolute path). Defaults to the repo's
# gitignored `data/` folder, so files the agent creates (and uploads) stay out
# of the project tree. Point it at a real project to work there instead.
# WORKDIR=/Users/you/projects

# Where per-chat session + usage state is persisted as JSON so it survives
# restarts (resume token, cwd, mode, allow-list, cost totals). Defaults to
# `data/state.json` in the repo's gitignored data/ folder.
# STATE_FILE=/Users/you/.claude-telegram/state.json

# Model to drive (defaults to latest Opus). e.g. claude-opus-4-8, claude-sonnet-4-6
CLAUDE_MODEL=claude-opus-4-8

# Optional: API key. If omitted, the SDK reuses your existing `claude` CLI login.
# ANTHROPIC_API_KEY=sk-ant-...

# Log verbosity: error | warn | info | debug (default info).
# Use debug to also see per-tool auto-allows, session ids, and button presses.
LOG_LEVEL=info

# Operator playbook appended to the system prompt every turn (default ./work.md).
# Define how recurring operational requests should be handled (services, crontab…).
# WORK_FILE=work.md

# How long (ms) to wait for a tool-approval button press before auto-denying.
APPROVAL_TIMEOUT_MS=300000

# Agentic loop detection: if the model fires the exact same tool call (name +
# input) this many times in a single turn, pause and ask Skip / Approve once /
# Continue (interactive turns) or stop the run with a notification (autonomous
# turns), so a runaway retry can't burn tokens overnight. Set to 0 to disable.
LOOP_THRESHOLD=3

# How replies stream back (private chats only for rich/draft):
#   rich  = Bot API 10.1 Rich Messages: structured markdown (headings, lists,
#           tables, code), streamed live and finalized as a rich message. Default.
#   draft = Bot API 9.3 sendMessageDraft: plain animated "Thinking…" preview,
#           finalized as a normal formatted message.
#   edit  = legacy: edit a placeholder message in place + typing indicator.
STREAM_MODE=rich

# Voice notes. Pick a backend with TRANSCRIBE_PROVIDER:
#   openai (default) = OpenAI-compatible /audio/transcriptions endpoint.
#   vosk             = fully local/offline recognition (no API, English models).
# Without a working backend, voice messages get a hint instead of processing.
TRANSCRIBE_PROVIDER=openai

# --- openai backend ---
# Works with OpenAI or any compatible host. For Groq's free tier, point the base
# URL at https://api.groq.com/openai/v1 and use model whisper-large-v3-turbo.
# OPENAI_API_KEY=sk-...
# TRANSCRIBE_MODEL=whisper-1
# TRANSCRIBE_BASE_URL=https://api.openai.com/v1

# --- vosk backend (local, offline) ---
# 1) npm install vosk   (optional native dependency)
# 2) install ffmpeg     (used to decode OGG/Opus voice notes to PCM)
# 3) download + unpack a model from https://alphacephei.com/vosk/models
#    e.g. vosk-model-small-en-us-0.15 (~40MB) and point VOSK_MODEL_PATH at it.
# VOSK_MODEL_PATH=/path/to/vosk-model-small-en-us-0.15
# FFMPEG_PATH=ffmpeg

# --- Semantic memory (Phase 2): local embeddings ---
# Auto by default: at startup the bot probes Ollama (:11434) then LM Studio (:1234)
# and enables embeddings against whichever is live, re-selecting on every restart.
# No configuration needed. Memory recall then matches by meaning (cosine similarity
# over the local model), and always falls back to keyword search when no backend
# is reachable, so nothing breaks if the endpoint is down.
#
# EMBEDDING_ENABLED is tri-state:
#   auto (default) = probe and auto-detect a live local backend, as described above.
#   on             = pin the EMBEDDING_* backend below instead of auto-detecting.
#   off            = force embeddings off and never probe (recall stays keyword-only).
# Panel users do not need this: the Settings page has an Auto / Manual / Off control.
# Setting on or off here locks that panel control. Leave unset for auto.
# EMBEDDING_ENABLED=auto
# Wire shape: "ollama" (POST /api/embeddings) or "openai" (POST /v1/embeddings,
# for LM Studio, OpenAI, most proxies).
# EMBEDDING_PROVIDER=ollama
# Endpoint base URL. For Ollama: http://localhost:11434 ; LM Studio: http://localhost:1234
# EMBEDDING_BASE_URL=http://localhost:11434
# Embedding model id. Ollama: nomic-embed-text (run `ollama pull nomic-embed-text`).
# OpenAI: text-embedding-3-small. LM Studio: whatever embedding model you loaded.
# EMBEDDING_MODEL=nomic-embed-text
# Optional auth token (plain or a vault:<id> reference) for the embedding endpoint.
# EMBEDDING_AUTH_TOKEN=

# --- Management panel (optional embedded web UI) ---
# A small dashboard (system health, sessions, schedules, usage) served in the
# same process. It can read host data, so it's OFF by default and REFUSES to
# start without PANEL_TOKEN. Bind stays on loopback; expose remotely only via a
# reverse proxy or a private network (e.g. tailscale), never raw 0.0.0.0.
# PANEL_ENABLED=true
# PANEL_TOKEN must be at least 16 chars (a long random secret). The panel rejects
# the token in the URL for REST calls (header only) and locks out an IP after 10
# failed attempts for 5 minutes, so brute-forcing it over the network is impractical.
# PANEL_TOKEN=choose-a-long-random-secret
# PANEL_HOST=127.0.0.1
# PANEL_PORT=8787
# The in-panel Chat drives a dedicated Claude session. On by default; set false
# to hide the Chat view and disable its endpoints.
# PANEL_CHAT_ENABLED=true
# By default the Chat gates every
# risky tool behind an approve/deny prompt in the panel. Set this true (and
# restart) to unlock its "auto" mode, which runs tools without asking.
# PANEL_CHAT_BYPASS=false
# The in-panel Terminal is a full interactive host shell over the WebSocket. A
# panel-token holder then has arbitrary command execution as the bot's user, so
# it is OFF by default. Set true (and restart) to enable it.
# PANEL_TERMINAL_ENABLED=false
# When the terminal is enabled it gets a minimal sanitized environment so a shell
# session can't read the bot's secrets (API keys, tokens from .env) back out via
# `env`. Set true to give the shell the bot's full environment instead (risky).
# PANEL_TERMINAL_INHERIT_ENV=false
