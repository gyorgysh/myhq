{
  "name": "myhq",
  "version": "0.1.0",
  "description": "Remote access to Claude Code over Telegram — stream a real Claude Code agent to your phone.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n bot,panel -c blue,green \"tsx watch src/index.ts\" \"npm run panel:watch\"",
    "dev:bot": "tsx watch src/index.ts",
    "build": "npm run build:panel && tsc -p tsconfig.json",
    "build:panel": "cd panel && npm install && npm run build",
    "panel:watch": "cd panel && npm install && npm run build -- --watch",
    "panel:dev": "cd panel && npm run dev",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "systeminformation": "^5.23.5",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "vosk": "^0.3.39"
  }
}
